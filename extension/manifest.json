{
  "manifest_version": 3,
  "name": "aSolve",
  "icons": {
  "16": "16x16.png",
  "48": "48x48.png",
  "128": "128x128.png"
  },
  "version": "1.0",
  "description": "AI Assitant for all of your problems that also makes the knowledge base from the conversation history",
  "permissions": ["activeTab", "storage","sidePanel","identity"],
  "host_permissions": [
    "https://api.asolve.me/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "aSolve"
  },
  "side_panel": {
    "default_path":"popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
  
}