{
  "manifest_version": 3,
  "name": "aSolve",
  "version": "1.0",
  "description": "AI explanations for WebWork problems",
  "permissions": ["activeTab", "scripting", "storage", "tabCapture","sidePanel","identity"],
  "host_permissions": [
    "http://localhost:8000/*",
    "https://*/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Simple Solver"
  },
  "side_panel": {
    "default_path":"popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*","file://*/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}